{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude HUD One",
  "version": "0.1.0",
  "identifier": "com.dec27.claude-hud-one",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "title": "Claude HUD One",
        "width": 644,
        "height": 90,
        "transparent": true,
        "decorations": false,
        "resizable": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true
      },
      {
        "label": "settings",
        "url": "settings.html",
        "title": "Claude HUD One Settings",
        "width": 960,
        "height": 660,
        "minWidth": 960,
        "maxWidth": 960,
        "minHeight": 560,
        "transparent": false,
        "decorations": true,
        "resizable": true,
        "shadow": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "resources/cleanup-claude-hud-one.ps1": "resources/cleanup-claude-hud-one.ps1",
      "resources/install-claude-hud-one-bridge.ps1": "resources/install-claude-hud-one-bridge.ps1",
      "resources/claude-status-bridge.mjs": "resources/claude-status-bridge.mjs"
    },
    "icon": ["icons/icon.ico"],
    "publisher": "Dec27-Lee",
    "shortDescription": "Claude Code dynamic island HUD for Windows",
    "longDescription": "Claude HUD One is a Windows 11 dynamic island HUD for Claude Code usage estimates, cost, overview, and current session status. Codex support is reserved for a later release.",
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      }
    }
  }
}
