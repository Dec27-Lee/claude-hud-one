{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/bridge/claude-status-bridge.mjs --hook",
            "timeout": 2
          },
          {
            "type": "command",
            "command": "python .claude/skills/work-journal/resources/hooks/reminder.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/bridge/claude-status-bridge.mjs --hook",
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/bridge/claude-status-bridge.mjs --hook",
            "timeout": 2
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/bridge/claude-status-bridge.mjs --hook",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/bridge/claude-status-bridge.mjs --hook",
            "timeout": 2
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/bridge/claude-status-bridge.mjs --hook",
            "timeout": 2
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/bridge/claude-status-bridge.mjs --hook",
            "timeout": 2
          },
          {
            "type": "command",
            "command": "python .claude/skills/work-journal/resources/hooks/reminder.py precompact",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
